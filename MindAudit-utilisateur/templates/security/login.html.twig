<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">
    <title>MindAudit - Connexion</title>

    <!-- Custom fonts for this template-->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Custom styles for this template-->
    <link href="{{ asset('css/auth.css') }}?v={{ 'now'|date('U') }}" rel="stylesheet">
</head>

<body class="bg-gradient-primary" data-turbo="false">
    <div class="container">
        <!-- Outer Row -->
        <div class="row justify-content-center">
            <div class="col-xl-10 col-lg-12 col-md-9">
                <div class="card o-hidden border-0 shadow-lg my-5">
                    <div class="card-body p-0">
                        <!-- Nested Row within Card Body -->
                        <div class="row">
                            <div class="col-lg-6 d-none d-lg-block bg-login-image"></div>
                            <div class="col-lg-6">
                                <div class="p-5">
                                    <div class="text-center">
                                        <h1 class="h4 text-gray-900 mb-4">Bienvenue !</h1>
                                    </div>

                                    {% if error %}
                                        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                                    {% endif %}

                                    {% for message in app.flashes('success') %}
                                        <div class="alert alert-success">{{ message }}</div>
                                    {% endfor %}

                                    <form class="user" method="post">
                                        <div class="form-group">
                                            <input type="email" 
                                                   class="form-control form-control-user"
                                                   id="inputEmail" 
                                                   name="email" 
                                                   value="{{ last_username }}" 
                                                   required 
                                                   autofocus
                                                   placeholder="Adresse Email...">
                                        </div>
                                        <div class="form-group">
                                            <input type="password" 
                                                   class="form-control form-control-user"
                                                   id="inputPassword" 
                                                   name="password" 
                                                   required
                                                   placeholder="Mot de passe">
                                        </div>
                                        <div class="form-group">
                                            <div class="custom-control custom-checkbox small">
                                                <input type="checkbox" class="custom-control-input" id="customCheck" name="_remember_me">
                                                <label class="custom-control-label" for="customCheck">Se souvenir de moi</label>
                                            </div>
                                        </div>

                                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                                        <button type="submit" class="btn btn-primary btn-user btn-block">
                                            Se connecter
                                        </button>
                                    </form>
                                    <hr>
                                    <div class="text-center mb-3">
                                        <p class="text-muted small">Ou connectez-vous avec</p>
                                    </div>
                                    <div class="row">
                                        <div class="col-6">
                                            <a href="{{ path('connect_google') }}" class="btn btn-danger btn-user btn-block">
                                                <i class="fab fa-google fa-fw"></i> Google
                                            </a>
                                        </div>
                                        <div class="col-6">
                                            <a href="{{ path('connect_facebook') }}" class="btn btn-primary btn-user btn-block" style="background-color: #3b5998;" onclick="console.log('Facebook button clicked')">
                                                <i class="fab fa-facebook-f fa-fw"></i> Facebook
                                            </a>
                                        </div>
                                    </div>
                                    <hr>
                                    <div class="text-center">
                                        <a class="small" href="{{ path('app_forgotten_password') }}">🔑 Mot de passe oublié ?</a>
                                    </div>
                                    <div class="text-center">
                                        <a class="small" href="{{ path('app_register') }}">Créer un compte !</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap core JavaScript-->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.0/js/bootstrap.bundle.min.js"></script>
    <!-- Chatbot Widget -->
    <div class="chatbot-widget">
        <!-- Chatbot Button -->
        <div id="chatbot-button" class="chatbot-button shadow">
            <div class="chatbot-icon">
                <i class="fas fa-robot"></i>
            </div>
            <div class="chatbot-text">
                <strong>Assistant IA</strong><br>
                <span>Posez votre question</span>
            </div>
            <div class="chatbot-toggle-icon">
                <i class="fas fa-chevron-up" id="chatbot-toggle-icon-inner"></i>
            </div>
        </div>

        <!-- Chatbot Window -->
        <div id="chatbot-window" class="chatbot-window shadow" style="display: none;">
            <div class="chatbot-header bg-primary text-white p-3 d-flex justify-content-between align-items-center">
                <div>
                    <i class="fas fa-robot mr-2"></i> Assistant MindAudit
                </div>
                <button id="chatbot-close" class="btn btn-sm btn-link text-white"><i class="fas fa-times"></i></button>
            </div>
            <div id="chatbot-messages" class="chatbot-messages p-3" style="height: 420px; overflow-y: auto; background-color: #f8f9fa;">
                <div class="chatbot-message bot-message text-left">
                    <span>Bonjour ! Comment puis-je vous aider avec MindAudit aujourd'hui ?</span>
                </div>
            </div>
            <div class="chatbot-input p-2 border-top bg-white">
                <form id="chatbot-form" class="d-flex m-0 align-items-center">
                    <input type="text" id="chatbot-input-field" class="form-control me-2" placeholder="Tapez votre message..." required style="border-radius: 20px; font-size: 1rem; padding: 10px 15px;">
                    <button type="submit" class="btn btn-primary" style="border-radius: 50%; width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;"><i class="fas fa-paper-plane" style="font-size: 1.2rem;"></i></button>
                </form>
            </div>
        </div>
    </div>

    <!-- Chatbot CSS -->
    <style>
        .chatbot-widget {
            position: fixed;
            bottom: 70px;
            right: 30px;
            z-index: 1000;
            font-family: 'Nunito', sans-serif;
        }
        .chatbot-button {
            background-color: #0056b3;
            color: white;
            border-radius: 40px;
            padding: 15px 25px;
            display: flex;
            align-items: center;
            cursor: pointer;
            box-shadow: 0 6px 12px rgba(0,0,0,0.3);
            transition: all 0.3s ease;
        }
        .chatbot-button:hover {
            background-color: #004494;
            transform: translateY(-2px);
        }
        .chatbot-icon {
            font-size: 32px;
            margin-right: 20px;
        }
        .chatbot-text {
            line-height: 1.3;
            margin-right: 20px;
            text-align: left;
        }
        .chatbot-text strong {
            font-size: 18px;
        }
        .chatbot-text span {
            font-size: 14px;
            opacity: 0.9;
        }
        .chatbot-window {
            position: absolute;
            bottom: 90px;
            right: 0;
            width: 420px;
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 8px 25px rgba(0,0,0,0.4);
            border: 1px solid #e3e6f0;
        }
        .chatbot-header {
            background-color: #0056b3 !important;
            font-size: 1.1rem;
            padding: 1rem !important;
        }
        .user-message {
            text-align: right;
            margin-bottom: 10px;
        }
        .user-message span {
            background-color: #e3e6f0;
            color: #333;
            padding: 12px 16px;
            border-radius: 15px 15px 0 15px;
            display: inline-block;
            max-width: 85%;
            font-size: 1rem;
            text-align: left;
        }
        .bot-message {
            text-align: left;
            margin-bottom: 12px;
        }
        .bot-message span {
            background-color: #0056b3 !important;
            color: white;
            padding: 12px 16px;
            border-radius: 15px 15px 15px 0;
            display: inline-block;
            max-width: 85%;
            font-size: 1rem;
            white-space: pre-wrap;
        }
        .typing-indicator {
            font-style: italic;
            color: #888;
            font-size: 0.8rem;
            margin-bottom: 10px;
        }
    </style>

    <!-- Chatbot JS -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const chatbotButton = document.getElementById('chatbot-button');
            const chatbotWindow = document.getElementById('chatbot-window');
            const chatbotClose = document.getElementById('chatbot-close');
            const chatbotForm = document.getElementById('chatbot-form');
            const chatbotInputField = document.getElementById('chatbot-input-field');
            const chatbotMessages = document.getElementById('chatbot-messages');
            const toggleIcon = document.getElementById('chatbot-toggle-icon-inner');

            chatbotButton.addEventListener('click', function() {
                if (chatbotWindow.style.display === 'none') {
                    chatbotWindow.style.display = 'block';
                    chatbotInputField.focus();
                    toggleIcon.classList.remove('fa-chevron-up');
                    toggleIcon.classList.add('fa-chevron-down');
                } else {
                    chatbotWindow.style.display = 'none';
                    toggleIcon.classList.remove('fa-chevron-down');
                    toggleIcon.classList.add('fa-chevron-up');
                }
            });

            chatbotClose.addEventListener('click', function(e) {
                e.stopPropagation();
                chatbotWindow.style.display = 'none';
                toggleIcon.classList.remove('fa-chevron-down');
                toggleIcon.classList.add('fa-chevron-up');
            });

            chatbotForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const message = chatbotInputField.value.trim();
                if (!message) return;

                // Add user message to UI
                addMessage(message, 'user');
                chatbotInputField.value = '';

                // Show typing indicator
                const typingId = 'typing-' + Date.now();
                chatbotMessages.insertAdjacentHTML('beforeend', `<div id="${typingId}" class="typing-indicator">L'assistant écrit...</div>`);
                chatbotMessages.scrollTop = chatbotMessages.scrollHeight;

                // Send to API
                fetch('/api/chatbot', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ message: message })
                })
                .then(response => response.json())
                .then(data => {
                    const typingEl = document.getElementById(typingId);
                    if (typingEl) typingEl.remove();
                    addMessage(data.reply, 'bot');
                })
                .catch(error => {
                    const typingEl = document.getElementById(typingId);
                    if (typingEl) typingEl.remove();
                    addMessage("Désolé, une erreur de connexion est survenue.", 'bot');
                    console.error('Chatbot error:', error);
                });
            });

            function addMessage(text, sender) {
                const messageDiv = document.createElement('div');
                messageDiv.className = `chatbot-message ${sender}-message`;
                
                const span = document.createElement('span');
                span.textContent = text;
                
                messageDiv.appendChild(span);
                chatbotMessages.appendChild(messageDiv);
                
                // Scroll to bottom
                chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
            }
        });
    </script>
</body>
</html>