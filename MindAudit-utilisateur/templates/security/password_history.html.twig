{% extends 'base.html.twig' %}

{% block title %}Historique de mes mots de passe - MindAudit{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <h1 class="mb-4">🔒 Historique de Sécurité - Mots de passe</h1>

            <!-- Alertes d'Anomalies -->
            {% if anomalies %}
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <h5 class="alert-heading">⚠️ Notifications de Sécurité Détectées</h5>
                    {% for anomaly in anomalies %}
                        <div class="mb-2">
                            <strong>{{ anomaly.message }}</strong>
                            <p class="mb-0 small text-muted">Sévérité: {{ anomaly.severity | upper }}</p>
                        </div>
                    {% endfor %}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endif %}

            <!-- Tableau Historique -->
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Derniers changements (10 derniers)</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>📅 Date</th>
                            <th>🏷️ Raison</th>
                            <th>📍 Adresse IP</th>
                            <th>🖥️ Appareil</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% if history %}
                            {% for change in history %}
                                <tr>
                                    <td>
                                        <strong>{{ change.changedAt|format_datetime('medium', locale='fr') }}</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">{{ change.reasonLabel }}</span>
                                    </td>
                                    <td>
                                        <code>{{ change.ipAddress|default('Inconnue') }}</code>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            {{ change.userAgent|default('Non disponible')|truncate(40) }}
                                        </small>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    Aucun changement de mot de passe détecté
                                </td>
                            </tr>
                        {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Actions de Sécurité -->
            <div class="mt-5">
                <h4>🔧 Actions de Sécurité</h4>
                <div class="row">
                    <div class="col-md-6">
                        <a href="{{ path('app_change_password') }}" class="btn btn-warning w-100">
                            💾 Modifier mon mot de passe maintenant
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="{{ path('app_user_space') }}" class="btn btn-secondary w-100">
                            ← Retour à mon profil
                        </a>
                    </div>
                </div>
            </div>

            <!-- Information de Sécurité -->
            <div class="alert alert-light border-start border-5 border-info mt-5">
                <h5>ℹ️ Conseils de Sécurité</h5>
                <ul class="mb-0">
                    <li>Changez régulièrement votre mot de passe (tous les 3 mois).</li>
                    <li>Si vous voyez des changements suspects, contactez immédiatement l'administrateur.</li>
                    <li>Activez la double authentification pour plus de sécurité.</li>
                    <li>Ne partagez jamais votre mot de passe avec personne.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}
