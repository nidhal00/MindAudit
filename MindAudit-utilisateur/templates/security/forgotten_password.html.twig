<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Mot de passe oublié - MindAudit{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f6f8;
            min-height: 100vh;
            display: flex;
            align-items: center;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        .reset-card {
            background: #ffffff;
            border-radius: 8px;
            border: 1px solid #e0e0e0;
            padding: 40px 35px;
            max-width: 450px;
            margin: auto;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }
        .reset-title {
            font-size: 22px;
            font-weight: 700;
            color: #000;
            text-align: center;
            margin-bottom: 25px;
        }
        .reset-text {
            font-size: 14px;
            color: #333;
            margin-bottom: 25px;
            line-height: 1.5;
        }
        .form-label {
            font-size: 13px;
            color: #555;
            margin-bottom: 6px;
        }
        .form-control {
            border: 1px solid #ced4da;
            border-radius: 4px;
            padding: 10px 12px;
            font-size: 14px;
        }
        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
        }
        .btn-primary {
            background-color: #0d6efd;
            border-color: #0d6efd;
            border-radius: 30px;
            padding: 10px 20px;
            font-weight: 600;
            font-size: 15px;
            letter-spacing: 0.3px;
        }
        .btn-primary:hover {
            background-color: #0b5ed7;
            border-color: #0a58ca;
        }
        .recaptcha-mock {
            border: 1px solid #d3d3d3;
            background: #f9f9f9;
            border-radius: 3px;
            padding: 10px 15px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 25px;
            width: 100%;
            max-width: 320px;
        }
        .recaptcha-checkbox {
            width: 26px;
            height: 26px;
            background: #fff;
            border: 2px solid #c1c1c1;
            border-radius: 2px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .recaptcha-checkbox.checked {
            border-color: #34a853;
        }
        .recaptcha-checkbox.checked::after {
            content: '✓';
            color: #34a853;
            font-size: 20px;
            font-weight: bold;
        }
        .recaptcha-checkbox.loading {
            border-top-color: #34a853;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { 100% { transform: rotate(360deg); } }
        .recaptcha-text {
            font-size: 14px;
            color: #555;
            flex-grow: 1;
        }
        .recaptcha-logo {
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .recaptcha-logo img {
            width: 28px;
            margin-bottom: 2px;
        }
        .recaptcha-logo small {
            display: block;
            font-size: 9px;
            color: #999;
            line-height: 1.1;
            text-align: center;
        }
        .back-link {
            display: block;
            text-align: center;
            font-size: 13px;
            color: #0d6efd;
            text-decoration: underline;
            margin-top: 15px;
        }
        .back-link:hover {
            color: #0b5ed7;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6 col-xl-5">
                <div class="reset-card">
                    <div class="reset-title">Mot de passe oublié ?</div>
                    
                    {% if message %}
                        <div class="alert alert-{{ messageType }} alert-dismissible fade show" role="alert" style="font-size: 14px;">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endif %}

                    <p class="reset-text">
                        Veuillez saisir votre email ou numéro de téléphone afin de recevoir le lien de réinitialisation de votre mot de passe.
                    </p>

                    {{ form_start(form) }}

                    <div class="mb-3">
                        {{ form_label(form.email, 'Email de connexion ou numéro', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'Saisir votre email ou numéro'}}) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div class="recaptcha-mock" id="recaptcha-container" style="cursor: pointer;">
                        <div class="d-flex align-items-center">
                            <div class="recaptcha-checkbox" id="recaptcha-checkbox"></div>
                            <div class="recaptcha-text">Je ne suis pas un robot</div>
                        </div>
                        <div class="recaptcha-logo">
                            <img src="https://www.gstatic.com/recaptcha/api2/logo_48.png" alt="reCAPTCHA">
                            <small>reCAPTCHA<br>Confidentialité - Conditions</small>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mb-3">
                        {{ form_widget(form.send_link, {'label': 'Recevoir le lien', 'attr': {'class': 'btn btn-primary', 'id': 'submit-btn', 'disabled': 'disabled'}}) }}
                    </div>
                    
                    <div class="d-none">
                        {{ form_widget(form.send_code) }}
                    </div>

                    {{ form_end(form) }}

                    <a href="{{ path('app_login') }}" class="back-link">retour à la page de connexion</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('recaptcha-container').addEventListener('click', function() {
            var checkbox = document.getElementById('recaptcha-checkbox');
            // On cherche le bouton de type submit dans le formulaire
            var submitBtn = document.querySelector('button[type="submit"]');
            
            if(!checkbox.classList.contains('checked')) {
                checkbox.classList.add('loading');
                setTimeout(function() {
                    checkbox.classList.remove('loading');
                    checkbox.classList.add('checked');
                    if (submitBtn) {
                        submitBtn.disabled = false; // Débloquer le bouton
                        submitBtn.style.opacity = "1";
                        submitBtn.style.cursor = "pointer";
                    }
                }, 800);
            }
        });
    </script>
</body>
</html>
