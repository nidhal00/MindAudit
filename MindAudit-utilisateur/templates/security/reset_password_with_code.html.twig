<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Entrer le code - MindAudit</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f6f8;
            min-height: 100vh;
            display: flex;
            align-items: center;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        .reset-card {
            background: #ffffff;
            border-radius: 8px;
            border: 1px solid #e0e0e0;
            padding: 40px 35px;
            max-width: 450px;
            margin: auto;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }
        .reset-title {
            font-size: 22px;
            font-weight: 700;
            color: #000;
            text-align: center;
            margin-bottom: 25px;
        }
        .reset-text {
            font-size: 14px;
            color: #333;
            margin-bottom: 25px;
            line-height: 1.5;
        }
        .form-label {
            font-size: 13px;
            color: #555;
            margin-bottom: 6px;
        }
        .form-control {
            border: 1px solid #ced4da;
            border-radius: 4px;
            padding: 10px 12px;
            font-size: 16px;
            letter-spacing: 2px;
            text-align: center;
        }
        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
        }
        .btn-primary {
            background-color: #0d6efd;
            border-color: #0d6efd;
            border-radius: 30px;
            padding: 10px 20px;
            font-weight: 600;
            font-size: 15px;
            letter-spacing: 0.3px;
        }
        .btn-primary:hover {
            background-color: #0b5ed7;
            border-color: #0a58ca;
        }
        .back-link {
            display: block;
            text-align: center;
            font-size: 13px;
            color: #0d6efd;
            text-decoration: underline;
            margin-top: 15px;
        }
        .back-link:hover {
            color: #0b5ed7;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6 col-xl-5">
                <div class="reset-card">
                    <div class="reset-title">Vérification de sécurité</div>
                    
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible fade show" role="alert" style="font-size: 14px;">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="font-size: 14px;">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    <p class="reset-text text-center">
                        Veuillez entrer le code à 6 caractères
                    </p>

                    {{ form_start(form) }}

                    <div class="mb-4">
                        {{ form_label(form.token, 'Code de vérification', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.token, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.token) }}
                    </div>

                    <div class="d-grid gap-2 mb-3">
                        {{ form_widget(form.submit, {'attr': {'class': 'btn btn-primary'}}) }}
                    </div>

                    {{ form_end(form) }}

                    <a href="{{ path('app_login') }}" class="back-link">retour à la page de connexion</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
