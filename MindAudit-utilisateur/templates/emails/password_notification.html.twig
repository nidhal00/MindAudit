{# Email de notification de sécurité #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 5px 5px 0 0; }
        .content { background: #f9f9f9; padding: 20px; border-radius: 0 0 5px 5px; border: 1px solid #ddd; border-top: none; }
        .footer { text-align: center; font-size: 12px; color: #999; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h2>🔐 Notification de Sécurité</h2>
        </div>
        <div class="content">
            <p>Bonjour {{ user.prenom }} {{ user.nom }},</p>

            {% if type == 'reset' %}
                <p>
                    <strong>Votre mot de passe a été réinitialisé</strong> le
                    <strong>{{ timestamp|format_datetime('medium', locale='fr') }}</strong>.
                </p>
                <p>
                    Si vous n'avez pas initié cette réinitialisation, <strong>veuillez contacter immédiatement l'équipe support</strong>.
                </p>
            {% elseif type == 'changed' %}
                <p>
                    <strong>Votre mot de passe a été modifié</strong> le
                    <strong>{{ timestamp|format_datetime('medium', locale='fr') }}</strong>.
                </p>
                <p>
                    Si ce n'est pas vous, changez immédiatement votre mot de passe et contactez le support.
                </p>
            {% endif %}

            <hr>

            <h3>📋 Actions Recommandées :</h3>
            <ul>
                <li>✓ Vérifiez votre activité récente sur MindAudit</li>
                <li>✓ Consultez l'historique de vos mots de passe</li>
                <li>✓ En cas de doute, changez votre mot de passe</li>
                <li>✓ Signalez toute activité suspecte</li>
            </ul>

            <hr>

            <p>
                <strong>Adresse email:</strong> {{ user.email }}<br>
                <strong>Heure:</strong> {{ timestamp|format_datetime('full', locale='fr') }}
            </p>

            <p class="footer">
                Cet email a été envoyé automatiquement. Ne répondez pas à ce message.
            </p>
        </div>
    </div>
</body>
</html>
