<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: DejaVu Sans, sans-serif; font-size: 11px; }
    h1 { font-size: 18px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border: 1px solid #ddd; padding: 5px; }
    th { background: #f8f9fa; }
  </style>
</head>
<body>
  <h1>Rapport d'audit</h1>
  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>Utilisateur</th>
        <th>Action</th>
        <th>Entité</th>
        <th>ID</th>
        <th>Détails</th>
      </tr>
    </thead>
    <tbody>
      {% for l in logs %}
      <tr>
        <td>{{ l.createdAt|date('d/m/Y H:i') }}</td>
        <td>{{ l.utilisateur ? l.utilisateur.nomComplet : 'Système' }}</td>
        <td>{{ l.action }}</td>
        <td>{{ l.entity ?: '-' }}</td>
        <td>{{ l.entityId ?: '-' }}</td>
        <td>{{ l.details ? l.details|json_encode : '-' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</body>
</html>
