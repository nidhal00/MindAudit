<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Rapport Utilisateurs - MindAudit</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 11px;
            color: #1a1a2e;
            background: #ffffff;
        }

        /* ══════════════════════════════
           EN-TÊTE PREMIUM
        ══════════════════════════════ */
        .header {
            position: relative;
            padding: 0;
            margin-bottom: 0;
            overflow: hidden;
        }
        .header-bg {
            background: #1a4d66;
            padding: 28px 40px 0 40px;
        }
        .header-brand {
            display: table;
            width: 100%;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.15);
        }
        .brand-left {
            display: table-cell;
            vertical-align: middle;
        }
        .brand-name {
            font-size: 30px;
            font-weight: bold;
            color: #ffffff;
            letter-spacing: 3px;
            text-transform: uppercase;
        }
        .brand-dot {
            color: #5dade2;
        }
        .brand-tagline {
            font-size: 10px;
            color: rgba(255,255,255,0.65);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-top: 3px;
        }
        .brand-right {
            display: table-cell;
            vertical-align: middle;
            text-align: right;
        }
        .report-badge {
            background: #5dade2;
            color: white;
            font-size: 9px;
            font-weight: bold;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 5px 14px;
            border-radius: 20px;
        }

        .header-info {
            display: table;
            width: 100%;
            padding: 14px 0 20px 0;
        }
        .header-info-left {
            display: table-cell;
            vertical-align: middle;
        }
        .header-title {
            font-size: 18px;
            font-weight: bold;
            color: #ffffff;
        }
        .header-subtitle {
            font-size: 10px;
            color: rgba(255,255,255,0.6);
            margin-top: 3px;
        }
        .header-info-right {
            display: table-cell;
            vertical-align: middle;
            text-align: right;
        }
        .header-date {
            font-size: 10px;
            color: rgba(255,255,255,0.75);
        }
        .header-date strong {
            color: #fff;
            font-size: 11px;
        }

        .header-stripe {
            height: 5px;
            background: linear-gradient(90deg, #5dade2 0%, #1abc9c 50%, #3498db 100%);
        }

        /* ══════════════════════════════
           SECTION STATISTIQUES
        ══════════════════════════════ */
        .stats-section {
            padding: 28px 40px 0 40px;
        }
        .section-title {
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 2.5px;
            color: #5dade2;
            font-weight: bold;
            border-bottom: 2px solid #5dade2;
            padding-bottom: 6px;
            margin-bottom: 18px;
        }

        .stats-row {
            display: table;
            width: 100%;
            border-spacing: 12px;
        }
        .stat-box {
            display: table-cell;
            width: 25%;
            padding: 18px 16px;
            border-radius: 10px;
            text-align: center;
            vertical-align: middle;
        }
        .stat-box.s1 { background: #eaf4fb; border-top: 4px solid #5dade2; }
        .stat-box.s2 { background: #e8f8f4; border-top: 4px solid #1abc9c; }
        .stat-box.s3 { background: #fdf0f0; border-top: 4px solid #e74c3c; }
        .stat-box.s4 { background: #fef9e7; border-top: 4px solid #f1c40f; }

        .stat-number { font-size: 36px; font-weight: bold; line-height: 1; }
        .s1 .stat-number { color: #2980b9; }
        .s2 .stat-number { color: #16a085; }
        .s3 .stat-number { color: #c0392b; }
        .s4 .stat-number { color: #d4ac0d; }
        
        .stat-label { font-size: 10px; color: #666; text-transform: uppercase; letter-spacing: 1px; margin-top: 6px; }
        .stat-icon { font-size: 20px; margin-bottom: 8px; }
        .s1 .stat-icon { color: #5dade2; }
        .s2 .stat-icon { color: #1abc9c; }
        .s3 .stat-icon { color: #e74c3c; }
        .s4 .stat-icon { color: #f1c40f; }

        /* ══════════════════════════════
           TABLEAU
        ══════════════════════════════ */
        .table-section {
            padding: 28px 40px 0 40px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            border-radius: 8px;
            overflow: hidden;
        }
        thead tr {
            background: #1a4d66;
        }
        thead th {
            padding: 11px 14px;
            text-align: left;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #fff;
            font-weight: bold;
        }
        tbody tr:nth-child(even) { background: #f4f9fc; }
        tbody tr:nth-child(odd) { background: #ffffff; }
        tbody td {
            padding: 9px 14px;
            font-size: 10.5px;
            border-bottom: 1px solid #e8edf3;
            color: #2c3e50;
            vertical-align: middle;
        }
        .td-num { color: #aaa; font-size: 10px; }
        .td-name { font-weight: bold; color: #1a4d66; }
        .td-email { color: #555; }

        .badge {
            display: inline-block;
            padding: 2px 9px;
            border-radius: 20px;
            font-size: 9px;
            font-weight: bold;
            letter-spacing: 0.5px;
        }
        .badge-admin { background: #fde8e8; color: #c0392b; border: 1px solid #f5c6c6; }
        .badge-user  { background: #d6eaf8; color: #1a6fa8; border: 1px solid #aed6f1; }
        .badge-auditeur { background: #fef9e7; color: #9a7d0a; border: 1px solid #f9e79f; }
        .badge-actif  { background: #d5f5e3; color: #1a8a4b; border: 1px solid #a9dfbf; }
        .badge-bloque { background: #fdedec; color: #c0392b; border: 1px solid #f5c6c6; }

        /* ══════════════════════════════
           PIED DE PAGE
        ══════════════════════════════ */
        .footer {
            margin-top: 36px;
        }
        .footer-stripe {
            height: 5px;
            background: linear-gradient(90deg, #5dade2 0%, #1abc9c 50%, #3498db 100%);
        }
        .footer-content {
            background: #1a4d66;
            padding: 14px 40px;
            display: table;
            width: 100%;
        }
        .footer-left {
            display: table-cell;
            vertical-align: middle;
            color: rgba(255,255,255,0.6);
            font-size: 9px;
        }
        .footer-left strong { color: #5dade2; }
        .footer-right {
            display: table-cell;
            vertical-align: middle;
            text-align: right;
            color: rgba(255,255,255,0.5);
            font-size: 9px;
        }
    </style>
</head>
<body>

<!-- ══════ EN-TÊTE ══════ -->
<div class="header">
    <div class="header-bg">
        <div class="header-brand">
            <div class="brand-left">
                <div class="brand-name">Mind<span class="brand-dot">Audit</span></div>
                <div class="brand-tagline">Plateforme d'Audit &amp; de Gestion des Utilisateurs</div>
            </div>
            <div class="brand-right">
                <span class="report-badge">Rapport Officiel</span>
            </div>
        </div>
        <div class="header-info">
            <div class="header-info-left">
                <div class="header-title">Rapport des Utilisateurs</div>
                <div class="header-subtitle">Vue d'ensemble complète des comptes enregistrés</div>
            </div>
            <div class="header-info-right">
                <div class="header-date">
                    <strong>{{ "now"|date("d/m/Y") }}</strong><br>
                    {{ "now"|date("H:i") }} — Usage interne confidentiel
                </div>
            </div>
        </div>
    </div>
    <div class="header-stripe"></div>
</div>

<!-- ══════ STATISTIQUES ══════ -->
<div class="stats-section">
    <div class="section-title">Résumé Global</div>
    <table class="stats-row" style="border-collapse: separate; border-spacing: 10px;">
        <tr>
            <td class="stat-box s1">
                <div class="stat-icon">&#128100;</div>
                <div class="stat-number">{{ users|length }}</div>
                <div class="stat-label">Total Comptes</div>
            </td>
            <td class="stat-box s2">
                <div class="stat-icon">&#10003;</div>
                <div class="stat-number">{{ users|filter(u => u.actif)|length }}</div>
                <div class="stat-label">Comptes Actifs</div>
            </td>
            <td class="stat-box s3">
                <div class="stat-icon">&#128274;</div>
                <div class="stat-number">{{ users|filter(u => not u.actif)|length }}</div>
                <div class="stat-label">Comptes Bloqués</div>
            </td>
            <td class="stat-box s4">
                <div class="stat-icon">&#128273;</div>
                <div class="stat-number">{{ totalRoles }}</div>
                <div class="stat-label">Total Rôles</div>
            </td>
        </tr>
    </table>
</div>

<!-- ══════ TABLEAU ══════ -->
<div class="table-section" style="margin-top: 28px;">
    <div class="section-title">Liste Complète des Comptes</div>
    <table>
        <thead>
            <tr>
                <th style="width:4%">#</th>
                <th style="width:22%">Nom Complet</th>
                <th style="width:30%">Adresse E-mail</th>
                <th style="width:16%">Rôle</th>
                <th style="width:14%">Statut</th>
                <th style="width:14%">Inscription</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr>
                <td class="td-num">{{ loop.index }}</td>
                <td class="td-name">{{ user.nomComplet }}</td>
                <td class="td-email">{{ user.email }}</td>
                <td>
                    {% if user.role %}
                        {% set rc = user.role.nom == 'Administrateur' ? 'badge-admin' : (user.role.nom == 'Auditeur' ? 'badge-auditeur' : 'badge-user') %}
                        <span class="badge {{ rc }}">{{ user.role.nom }}</span>
                    {% else %}
                        <span class="badge badge-user">Utilisateur</span>
                    {% endif %}
                </td>
                <td>
                    {% if user.actif %}
                        <span class="badge badge-actif">&#10003; Actif</span>
                    {% else %}
                        <span class="badge badge-bloque">&#128274; Bloqué</span>
                    {% endif %}
                </td>
                <td>{{ user.createdAt ? user.createdAt|date('d/m/Y') : '—' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<!-- ══════ PIED DE PAGE ══════ -->
<div class="footer">
    <div class="footer-stripe"></div>
    <div class="footer-content">
        <div class="footer-left">
            <strong>MindAudit</strong> — Document généré automatiquement le {{ "now"|date("d/m/Y à H:i") }}
        </div>
        <div class="footer-right">
            Confidentiel · Usage interne uniquement · Reproduction interdite
        </div>
    </div>
</div>

</body>
</html>
