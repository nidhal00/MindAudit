# ========================================
# FICHIER DE CONFIGURATION LOCALE
# ========================================
# Copiez ce fichier en .env.local et remplissez avec vos vraies valeurs
# NE COMMITEZ JAMAIS ce fichier dans Git !
#
# Commande: copy .env.local.example .env.local
#

###> knpuniversity/oauth2-client-bundle ###
# ========================================
# GOOGLE OAUTH2
# ========================================
# Obtenez vos identifiants sur: https://console.cloud.google.com/
# 
# Étapes:
# 1. Créez un projet
# 2. Activez l'API Google+
# 3. Créez des identifiants OAuth 2.0 (Application Web)
# 4. Ajoutez l'URI de redirection: http://localhost:8000/connect/google/check
# 5. Copiez le Client ID et le Client Secret ci-dessous
#
# Format attendu:
# - Client ID: 123456789-abcdefghijklmnop.apps.googleusercontent.com
# - Client Secret: GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
#
GOOGLE_CLIENT_ID=495283603649-8ag8p84a7jn8crmr2sh8cam53l4cl2hp.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=OCSPX-3lgkOPsmA_fIoz-RLhRKIumUSy7B

# ========================================
# FACEBOOK OAUTH2
# ========================================
# Obtenez vos identifiants sur: https://developers.facebook.com/
#
# Étapes:
# 1. Créez une application (type: Consommateur)
# 2. Configurez Facebook Login
# 3. Ajoutez l'URI de redirection: http://localhost:8000/connect/facebook/check
# 4. Copiez l'App ID et l'App Secret ci-dessous
# 5. Passez l'application en mode "Live" (pour les utilisateurs publics)
#
# Format attendu:
# - App ID: 1234567890123456 (numérique)
# - App Secret: abcdef1234567890abcdef1234567890 (32 caractères hexadécimaux)
#
FACEBOOK_CLIENT_ID=votre_app_id_facebook_ici
FACEBOOK_CLIENT_SECRET=votre_app_secret_facebook_ici
###< knpuniversity/oauth2-client-bundle ###

# ========================================
# DOCUMENTATION
# ========================================
