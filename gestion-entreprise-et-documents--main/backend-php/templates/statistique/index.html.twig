{% extends 'admin/base.html.twig' %}

{% block title %}Statistiques - MindAudit{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 fw-bold"><i class="fa-solid fa-chart-line text-primary me-2"></i>Analyses & Statistiques</h1>
        <button onclick="window.print()" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-download fa-sm text-white-50 me-1"></i> Générer Rapport
        </button>
    </div>

    <!-- Stats Overview Cards -->
    <div class="row">
        <!-- Entreprises Actives -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Entreprises Actives</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ total_active }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Entreprises en Attente -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                En Attente</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ total_pending }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content Row -->
    <div class="row">
        <!-- Inscriptions par Mois -->
        <div class="col-xl-12 col-lg-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Inscriptions par Mois</h6>
                </div>
                <div class="card-body">
                    <div class="chart-area" style="height: 300px;">
                        <canvas id="monthlyRegistrationChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Type 1: Répartition Metier -->
        <div class="col-xl-6 col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Répartition par Secteur d'Activité</h6>
                </div>
                <div class="card-body">
                    <div class="chart-pie pt-4 pb-2">
                        <canvas id="sectorPieChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-6 col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-success">Statut des Documents</h6>
                </div>
                <div class="card-body">
                    <div class="chart-bar pt-4 pb-2">
                        <canvas id="statusBarChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Type 2: Performance IA -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">Analyse de Performance IA par Secteur</h6>
                </div>
                <div class="card-body">
                    <div class="chart-area">
                        <canvas id="iaPerformanceChart" height="100"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Monthly Registration Chart
        new Chart(document.getElementById('monthlyRegistrationChart'), {
            type: 'line',
            data: {
                labels: [{% for stat in monthly_stats %}"{{ stat.month }}"{% if not loop.last %}, {% endif %}{% endfor %}],
                datasets: [{
                    label: "Inscriptions",
                    data: [{% for stat in monthly_stats %}{{ stat.count }}{% if not loop.last %}, {% endif %}{% endfor %}],
                    borderColor: '#4e73df',
                    backgroundColor: 'rgba(78, 115, 223, 0.1)',
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                maintainAspectRatio: false,
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1 } }
                }
            }
        });

        // Secteur Pie Chart
        new Chart(document.getElementById('sectorPieChart'), {
            type: 'pie',
            data: {
                labels: [{% for stat in sector_stats %}"{{ stat.label }}"{% if not loop.last %}, {% endif %}{% endfor %}],
                datasets: [{
                    data: [{% for stat in sector_stats %}{{ stat.value }}{% if not loop.last %}, {% endif %}{% endfor %}],
                    backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b', '#858796'],
                    hoverBackgroundColor: ['#2e59d9', '#17a673', '#2c9faf', '#dda20a', '#be2617', '#60616f'],
                    hoverBorderColor: "rgba(234, 236, 244, 1)",
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } }
            }
        });

        // Status Bar Chart
        new Chart(document.getElementById('statusBarChart'), {
            type: 'bar',
            data: {
                labels: [{% for stat in status_stats %}"{{ stat.label|capitalize }}"{% if not loop.last %}, {% endif %}{% endfor %}],
                datasets: [{
                    label: "Nombre de documents",
                    backgroundColor: "#1cc88a",
                    hoverBackgroundColor: "#17a673",
                    borderColor: "#1cc88a",
                    data: [{% for stat in status_stats %}{{ stat.value }}{% if not loop.last %}, {% endif %}{% endfor %}],
                }]
            },
            options: {
                maintainAspectRatio: false,
                scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
            }
        });

        // IA Performance Radar/Bar Chart
        new Chart(document.getElementById('iaPerformanceChart'), {
            type: 'line',
            data: {
                labels: [{% for stat in ia_stats %}"{{ stat.label }}"{% if not loop.last %}, {% endif %}{% endfor %}],
                datasets: [{
                    label: "Score Moyen de Conformité (%)",
                    lineTension: 0.3,
                    backgroundColor: "rgba(78, 115, 223, 0.05)",
                    borderColor: "rgba(78, 115, 223, 1)",
                    pointRadius: 3,
                    pointBackgroundColor: "rgba(78, 115, 223, 1)",
                    pointBorderColor: "rgba(78, 115, 223, 1)",
                    pointHoverRadius: 3,
                    pointHoverBackgroundColor: "rgba(78, 115, 223, 1)",
                    pointHoverBorderColor: "rgba(78, 115, 223, 1)",
                    pointHitRadius: 10,
                    pointBorderWidth: 2,
                    data: [{% for stat in ia_stats %}{{ stat.value|round(1) }}{% if not loop.last %}, {% endif %}{% endfor %}],
                }]
            },
            options: {
                maintainAspectRatio: false,
                scales: { y: { beginAtZero: true, max: 100 } }
            }
        });
    });
</script>
{% endblock %}
