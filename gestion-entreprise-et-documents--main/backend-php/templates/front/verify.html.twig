{% extends 'front/base.html.twig' %}

{% block title %}Vérification - {{ entreprise.nom }}{% endblock %}

{% block body %}
<!-- Start Breadcrumbs -->
<div class="breadcrumbs">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 col-md-6 col-12">
                <div class="breadcrumbs-content">
                    <h1 class="page-title">Vérification d'Entreprise</h1>
                </div>
            </div>
            <div class="col-lg-6 col-md-6 col-12">
                <ul class="breadcrumb-nav">
                    <li><a href="{{ path('app_front_home') }}">Accueil</a></li>
                    <li>Vérification</li>
                </ul>
            </div>
        </div>
    </div>
</div>
<!-- End Breadcrumbs -->

<section class="section service-single">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 offset-lg-2">
                <div class="service-details-content card shadow-sm p-4">
                    <div class="text-center mb-4">
                        <div class="icon mb-3">
                            <i class="lni lni-checkmark-circle text-success" style="font-size: 4rem;"></i>
                        </div>
                        <h2 class="mb-2">Authenticité Vérifiée</h2>
                        <p class="text-muted">Les informations ci-dessous sont certifiées par MindAudit.</p>
                    </div>
                    
                    <hr>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Nom de l'entreprise :</strong>
                            <p class="lead">{{ entreprise.nom }}</p>
                        </div>
                        <div class="col-md-6">
                            <strong>Matricule Fiscal :</strong>
                            <p class="lead">{{ entreprise.matriculeFiscale }}</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Secteur :</strong>
                            <p>{{ entreprise.secteur|default('Non spécifié') }}</p>
                        </div>
                        <div class="col-md-6">
                            <strong>Taille :</strong>
                            <p>{{ entreprise.taille|capitalize|default('Non spécifié') }}</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Email :</strong>
                            <p><a href="mailto:{{ entreprise.email }}">{{ entreprise.email }}</a></p>
                        </div>
                        <div class="col-md-6">
                            <strong>Téléphone :</strong>
                            <p>{{ entreprise.telephone|default('Non renseigné') }}</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-12">
                            <strong>Adresse :</strong>
                            <p>{{ entreprise.adresse|nl2br|default('Non renseignée') }}</p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <strong>Pays :</strong>
                            <p>{{ entreprise.pays|default('Non spécifié') }}</p>
                        </div>
                        <div class="col-md-6">
                            <strong>Date d'inscription :</strong>
                            <p>{{ entreprise.dateCreation ? entreprise.dateCreation|date('d/m/Y') : '-' }}</p>
                        </div>
                    </div>

                    <div class="alert alert-info text-center">
                        <i class="lni lni-shield"></i> Cette entreprise est enregistrée et validée sur la plateforme MindAudit.
                    </div>
                    
                    <div class="text-center mt-4">
                        <a href="{{ path('app_front_home') }}" class="btn btn-primary">Retour à l'accueil</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
