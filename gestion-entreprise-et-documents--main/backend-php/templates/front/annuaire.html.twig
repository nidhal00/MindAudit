{% extends 'front/base.html.twig' %}

{% block title %}Annuaire Entreprises - MindAudit{% endblock %}

{% block body %}
    <section class="section">
        <div class="container">
            <div class="section-title-five text-center">
                <div class="container">
                    <div class="row">
                        <div class="col-12">
                            <div class="content">
                                <h6>Annuaire</h6>
                                <h2 class="fw-bold">Entreprises Certifiées</h2>
                                <p>Découvrez les entreprises certifiées et auditées par notre plateforme.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
            {% for entreprise in entreprises %}
                <div class="col-lg-6 mb-4">
                    <div class="card shadow-sm border-0 rounded-3 p-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 p-4 rounded-circle me-4 text-primary">
                                <i class="fa-solid fa-building fa-2x"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-1">{{ entreprise.nom }}</h5>
                                <p class="text-muted mb-0"><i class="fa-solid fa-location-dot me-1"></i> {{ entreprise.secteur }} - {{ entreprise.pays }}</p>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-info text-white rounded-pill">{{ entreprise.taille|capitalize }}</span>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-warning py-4 text-center text-dark">
                        <i class="fa-solid fa-triangle-exclamation fa-2x mb-3 d-block"></i>
                        Aucune entreprise répertoriée pour le moment.
                    </div>
                </div>
            {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}

