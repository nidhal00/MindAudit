{% extends 'front/base.html.twig' %}

{% block title %}Récupération Code - MindAudit{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8 col-md-9">
            <div class="card o-hidden border-0 shadow-lg my-5">
                <div class="card-body p-0">
                    <div class="p-5">
                        <div class="text-center">
                            <h1 class="h4 text-gray-900 mb-4">Récupération de Code</h1>
                            <p class="mb-4">Entrez l'email utilisé lors de votre inscription. Nous vous renverrons votre code d'accès.</p>
                        </div>

                        {% if success %}
                            <div class="alert alert-success">{{ success }}</div>
                        {% endif %}
                        
                        {% if error %}
                            <div class="alert alert-danger">{{ error }}</div>
                        {% endif %}

                        <form method="post" class="user" novalidate>
                            <div class="form-group">
                                <input type="email" name="email" class="form-control form-control-user"
                                       placeholder="Entrez votre email..." required>
                            </div>
                            <button type="submit" class="btn btn-primary btn-user btn-block">
                                Envoyer mon code
                            </button>
                        </form>
                        <hr>
                        <div class="text-center">
                            <a class="small" href="{{ path('app_employee_login') }}">Retour à la connexion</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
