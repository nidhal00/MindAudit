<table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
    <thead>
        <tr>
            <th class="sortable-header" data-sort="nom">Nom</th>
            <th class="sortable-header" data-sort="secteur">Secteur</th>
            <th class="sortable-header" data-sort="taille">Taille</th>
            <th class="sortable-header" data-sort="pays">Pays</th>
            <th class="sortable-header" data-sort="statut">Statut</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for entreprise in entreprises %}
        <tr>
            <td>{{ entreprise.nom }}</td>
            <td>{{ entreprise.secteur }}</td>
            <td>{{ entreprise.taille }}</td>
            <td>{{ entreprise.pays }}</td>
            <td>
                <span class="badge badge-{{ entreprise.statut == 'valide' ? 'success' : (entreprise.statut == 'rejete' ? 'danger' : 'warning') }}">
                    {{ entreprise.statut|capitalize }}
                </span>
            </td>
            <td>
                <a href="{{ path('app_entreprise_show', {'id': entreprise.id}) }}" class="btn btn-info btn-circle btn-sm" title="Voir">
                    <i class="fas fa-eye"></i>
                </a>
                <a href="{{ path('app_entreprise_edit', {'id': entreprise.id}) }}" class="btn btn-primary btn-circle btn-sm" title="Modifier">
                    <i class="fas fa-edit"></i>
                </a>
                {{ include('admin/entreprise/_delete_form.html.twig') }}
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="6" class="text-center">Aucune entreprise trouvée</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{% if totalPages > 1 %}
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-3">
        {% if currentPage > 1 %}
            <li class="page-item">
                <a class="page-link" href="{{ path('app_entreprise_index', {'page': currentPage - 1}) }}">Précédent</a>
            </li>
        {% endif %}
        
        {% for page in 1..totalPages %}
            {% if page == currentPage %}
                <li class="page-item active"><span class="page-link">{{ page }}</span></li>
            {% elseif page == 1 or page == totalPages or (page >= currentPage - 2 and page <= currentPage + 2) %}
                <li class="page-item"><a class="page-link" href="{{ path('app_entreprise_index', {'page': page}) }}">{{ page }}</a></li>
            {% elseif page == currentPage - 3 or page == currentPage + 3 %}
                <li class="page-item disabled"><span class="page-link">...</span></li>
            {% endif %}
        {% endfor %}
        
        {% if currentPage < totalPages %}
            <li class="page-item">
                <a class="page-link" href="{{ path('app_entreprise_index', {'page': currentPage + 1}) }}">Suivant</a>
            </li>
        {% endif %}
    </ul>
    <p class="text-center text-muted">Page {{ currentPage }} sur {{ totalPages }} ({{ totalItems }} entreprises)</p>
</nav>
{% endif %}
