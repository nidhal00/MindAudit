<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Fiche Entreprise - {{ entreprise.nom }}</title>
    <style>
        body { font-family: Arial, sans-serif; font-size: 14px; color: #333; }
        .header { text-align: center; margin-bottom: 30px; border-bottom: 2px solid #0d6efd; padding-bottom: 10px; }
        .header h1 { color: #0d6efd; margin: 0; }
        .section { margin-bottom: 20px; }
        .section-title { font-size: 16px; font-weight: bold; color: #555; border-bottom: 1px solid #ddd; margin-bottom: 10px; padding-bottom: 5px; }
        .row { margin-bottom: 8px; }
        .label { font-weight: bold; width: 150px; display: inline-block; }
        .value { display: inline-block; }
        .badge { background-color: #f8f9fa; border: 1px solid #ddd; padding: 2px 5px; border-radius: 4px; font-size: 12px; }
        .footer { text-align: center; font-size: 10px; color: #999; margin-top: 50px; border-top: 1px solid #eee; padding-top: 10px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>{{ entreprise.nom }}</h1>
        <p>Matricule Fiscale: {{ entreprise.matriculeFiscale }}</p>
    </div>

    <div class="section">
        <div class="section-title">Informations Générales</div>
        <div class="row">
            <span class="label">Secteur :</span>
            <span class="value">{{ entreprise.secteur }}</span>
        </div>
        <div class="row">
            <span class="label">Taille :</span>
            <span class="value">{{ entreprise.taille|capitalize }}</span>
        </div>
        <div class="row">
            <span class="label">Date de création :</span>
            <span class="value">{{ entreprise.dateCreation ? entreprise.dateCreation|date('d/m/Y') : 'N/A' }}</span>
        </div>
    </div>

    <div class="section">
        <div class="section-title">Coordonnées</div>
        <div class="row">
            <span class="label">Pays :</span>
            <span class="value">{{ entreprise.pays }}</span>
        </div>
        <div class="row">
            <span class="label">Email :</span>
            <span class="value">{{ entreprise.email }}</span>
        </div>
        <div class="row">
            <span class="label">Téléphone :</span>
            <span class="value">{{ entreprise.telephone }}</span>
        </div>
        <div class="row">
            <span class="label">Adresse :</span>
            <span class="value">{{ entreprise.adresse }}</span>
        </div>
    </div>

    <div class="footer">
        <p>Généré par MindAudit le {{ "now"|date("d/m/Y à H:i") }}</p>
    </div>
</body>
</html>
