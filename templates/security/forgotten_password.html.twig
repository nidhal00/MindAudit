<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Mot de passe oublié - MindAudit{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .card { border-radius: 10px; }
        .card-header { border-radius: 10px 10px 0 0; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-lg mt-5 mb-5">
                    <div class="card-header bg-danger text-white">
                        <h2 class="mb-0">🔑 Réinitialiser mon mot de passe</h2>
                    </div>
                    <div class="card-body">
                        {% if message %}
                            <div class="alert alert-{{ messageType }} alert-dismissible fade show" role="alert">
                                {{ message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endif %}

                        <p class="text-muted mb-4">
                            Entrez votre adresse email pour recevoir un lien de réinitialisation.
                            <strong>Le lien expire après 15 minutes.</strong>
                        </p>

                        {{ form_start(form, {'attr': {'novalidate': true}}) }}

                        <div class="mb-3">
                            {{ form_label(form.email, 'Votre email', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.email) }}
                            {{ form_errors(form.email) }}
                            <small class="form-text text-muted">
                                Nous n'exposerons pas votre email publiquement.
                            </small>
                        </div>

                        <div class="d-grid gap-2">
                            {{ form_widget(form.send_link) }}
                        </div>

                        {{ form_end(form) }}

                        <hr class="my-4">

                        <div class="mt-4 text-center">
                            <p>Vous vous souvenez de votre mot de passe ?</p>
                            <a href="{{ path('app_login') }}" class="btn btn-outline-primary me-2">
                                ← Retour à la connexion
                            </a>
                            
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
