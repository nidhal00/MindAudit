<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Réinitialiser le mot de passe - MindAudit</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .card { border-radius: 10px; }
        .card-header { border-radius: 10px 10px 0 0; }
        .success-message {
            background-color: #d4edda;
            border: 1px solid #c3e6cb;
            color: #155724;
            padding: 15px;
            border-radius: 5px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-lg mt-5 mb-5">
                    <div class="card-header bg-danger text-white">
                        <h2 class="mb-0">🔑 Réinitialiser mon mot de passe</h2>
                    </div>
                    <div class="card-body">
                        <div class="success-message">
                            <i class="fas fa-check-circle"></i> <strong>Le code a été envoyé !</strong>
                            <p class="mb-0 mt-2">Vérifiez votre boîte email et entrez le code ci-dessous. <strong>Le code expire après 15 minutes.</strong></p>
                        </div>

                        {% for message in app.flashes('error') %}
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                {{ message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endfor %}

                        {{ form_start(form, {'attr': {'novalidate': true}}) }}

                        <div class="mb-3">
                            {{ form_label(form.token, 'Code de vérification', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.token, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Entrez le code reçu par email'}}) }}
                            {{ form_errors(form.token) }}
                            <small class="form-text text-muted">
                                Le code est composé de 6 caractères alphanumériques.
                            </small>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.password.first, 'Nouveau mot de passe', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.password.first, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Entrez votre nouveau mot de passe'}}) }}
                            {{ form_errors(form.password.first) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.password.second, 'Confirmer le mot de passe', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.password.second, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Confirmez votre nouveau mot de passe'}}) }}
                            {{ form_errors(form.password.second) }}
                        </div>

                        <div class="d-grid gap-2">
                            {{ form_widget(form.submit, {'attr': {'class': 'btn btn-primary btn-lg'}, 'label': '🔒 Réinitialiser mon mot de passe'}) }}
                        </div>

                        {{ form_end(form) }}

                        <hr class="my-4">

                        <div class="text-center">
                            <p class="mb-2">Vous vous souvenez de votre mot de passe ?</p>
                            <a href="{{ path('app_login') }}" class="btn btn-outline-primary">
                                ← Retour à la connexion
                            </a>
                        </div>

                        <div class="mt-3 text-center">
                            <small class="text-muted">
                                <i class="fas fa-info-circle"></i> Si vous avez reçu un lien par email, vous pouvez aussi l'utiliser directement.
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
