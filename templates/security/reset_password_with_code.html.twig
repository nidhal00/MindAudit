<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Réinitialiser le mot de passe - MindAudit</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-lg mt-5 mb-5">
                    <div class="card-header bg-danger text-white">
                        <h2 class="mb-0">🔑 Entrer le code et créer un nouveau mot de passe</h2>
                    </div>
                    <div class="card-body">
                        {{ form_start(form, {'attr': {'novalidate': true}}) }}

                        <div class="mb-3">
                            {{ form_label(form.token) }}
                            {{ form_widget(form.token) }}
                            {{ form_errors(form.token) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.password.first, 'Nouveau mot de passe') }}
                            {{ form_widget(form.password.first) }}
                            {{ form_errors(form.password.first) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.password.second, 'Confirmer le mot de passe') }}
                            {{ form_widget(form.password.second) }}
                            {{ form_errors(form.password.second) }}
                        </div>

                        {{ form_widget(form.submit) }}

                        {{ form_end(form) }}

                        <hr>
                        <p class="small text-muted">Si vous avez reçu un lien, vous pouvez aussi l'utiliser directement depuis votre email.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
