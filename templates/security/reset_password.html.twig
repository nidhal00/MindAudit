<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Réinitialiser le mot de passe - MindAudit{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .card { border-radius: 10px; }
        .card-header { border-radius: 10px 10px 0 0; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-lg mt-5 mb-5">
                    <div class="card-header bg-success text-white">
                        <h2 class="mb-0">🔐 Créer un nouveau mot de passe</h2>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info alert-dismissible fade show" role="alert">
                            <strong>💡 Conseil :</strong> Utilisez un mot de passe unique et sûr avec au moins 8 caractères,
                            incluant majuscules, minuscules, chiffres et caractères spéciaux.
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>

                        {{ form_start(form, {'attr': {'novalidate': true}}) }}

                        <div class="mb-4">
                            {{ form_label(form.password.first, 'Nouveau mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.password.first) }}
                            {{ form_errors(form.password.first) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.password.second, 'Confirmer le mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.password.second) }}
                            {{ form_errors(form.password.second) }}
                        </div>

                        {{ form_widget(form.submit, {'attr': {'class': 'w-100'}}) }}

                        {{ form_end(form) }}

                        <hr class="my-4">

                        <div class="text-muted small">
                            <p>
                                <strong>Exigences de sécurité :</strong>
                            </p>
                            <ul>
                                <li>✓ Minimum 8 caractères</li>
                                <li>✓ Unique et difficile à deviner</li>
                                <li>✓ Ne pas utiliser d'informations personnelles</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
