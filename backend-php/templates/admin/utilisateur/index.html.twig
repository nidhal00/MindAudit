{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Utilisateurs{% endblock %}

{% block body %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Gestion des Utilisateurs</h1>
    <a href="{{ path('app_admin_utilisateur_new') }}" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
        <i class="fas fa-plus fa-sm text-white-50"></i> Nouvel Utilisateur
    </a>
</div>

<!-- Search and Filter -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Recherche et Filtres</h6>
    </div>
    <div class="card-body">
        <form method="get" class="form-inline">
            <div class="form-group mr-2 mb-2">
                <input type="text" name="search" class="form-control" placeholder="Rechercher..." value="{{ search }}">
            </div>
            <div class="form-group mr-2 mb-2">
                <select name="role" class="form-control">
                    <option value="">Tous les rôles</option>
                    {% for role in roles %}
                        <option value="{{ role.id }}" {% if roleFilter == role.id %}selected{% endif %}>{{ role.nom }}</option>
                    {% endfor %}
                </select>
            </div>
            <button type="submit" class="btn btn-primary mb-2">
                <i class="fas fa-search"></i> Rechercher
            </button>
            {% if search or roleFilter %}
                <a href="{{ path('app_admin_utilisateur_index') }}" class="btn btn-secondary mb-2 ml-2">
                    <i class="fas fa-times"></i> Réinitialiser
                </a>
            {% endif %}
        </form>
    </div>
</div>

<!-- DataTales -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Liste des Utilisateurs ({{ utilisateurs|length }})</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>
                            <a href="{{ path('app_admin_utilisateur_index', {sort: 'nom', order: (sortBy == 'nom' and order == 'ASC') ? 'DESC' : 'ASC', search: search, role: roleFilter}) }}">
                                Nom
                                {% if sortBy == 'nom' %}
                                    <i class="fas fa-sort-{{ order == 'ASC' ? 'up' : 'down' }}"></i>
                                {% endif %}
                            </a>
                        </th>
                        <th>
                            <a href="{{ path('app_admin_utilisateur_index', {sort: 'prenom', order: (sortBy == 'prenom' and order == 'ASC') ? 'DESC' : 'ASC', search: search, role: roleFilter}) }}">
                                Prénom
                                {% if sortBy == 'prenom' %}
                                    <i class="fas fa-sort-{{ order == 'ASC' ? 'up' : 'down' }}"></i>
                                {% endif %}
                            </a>
                        </th>
                        <th>
                            <a href="{{ path('app_admin_utilisateur_index', {sort: 'email', order: (sortBy == 'email' and order == 'ASC') ? 'DESC' : 'ASC', search: search, role: roleFilter}) }}">
                                Email
                                {% if sortBy == 'email' %}
                                    <i class="fas fa-sort-{{ order == 'ASC' ? 'up' : 'down' }}"></i>
                                {% endif %}
                            </a>
                        </th>
                        <th>Rôle</th>
                        <th>Statut</th>
                        <th>Date création</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for utilisateur in utilisateurs %}
                        <tr>
                            <td>{{ utilisateur.nom }}</td>
                            <td>{{ utilisateur.prenom }}</td>
                            <td>{{ utilisateur.email }}</td>
                            <td>
                                <span class="badge badge-info">{{ utilisateur.role.nom }}</span>
                            </td>
                            <td>
                                {% if utilisateur.actif %}
                                    <span class="badge badge-success">Actif</span>
                                {% else %}
                                    <span class="badge badge-danger">Inactif</span>
                                {% endif %}
                            </td>
                            <td>{{ utilisateur.createdAt|date('d/m/Y') }}</td>
                            <td>
                                <a href="{{ path('app_admin_utilisateur_show', {id: utilisateur.id}) }}" class="btn btn-info btn-sm" title="Voir">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('app_admin_utilisateur_edit', {id: utilisateur.id}) }}" class="btn btn-warning btn-sm" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="{{ path('app_admin_utilisateur_toggle', {id: utilisateur.id}) }}" style="display:inline-block;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ utilisateur.id) }}">
                                    <button type="submit" class="btn btn-{{ utilisateur.actif ? 'secondary' : 'success' }} btn-sm" title="{{ utilisateur.actif ? 'Désactiver' : 'Activer' }}">
                                        <i class="fas fa-{{ utilisateur.actif ? 'ban' : 'check' }}"></i>
                                    </button>
                                </form>
                                <button type="button" class="btn btn-danger btn-sm" data-toggle="modal" data-target="#deleteModal{{ utilisateur.id }}" title="Supprimer">
                                    <i class="fas fa-trash"></i>
                                </button>

                                <!-- Delete Modal -->
                                <div class="modal fade" id="deleteModal{{ utilisateur.id }}" tabindex="-1" role="dialog">
                                    <div class="modal-dialog" role="document">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Confirmer la suppression</h5>
                                                <button type="button" class="close" data-dismiss="modal">
                                                    <span>&times;</span>
                                                </button>
                                            </div>
                                            <div class="modal-body">
                                                Êtes-vous sûr de vouloir supprimer l'utilisateur <strong>{{ utilisateur.nomComplet }}</strong> ?
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                                                <form method="post" action="{{ path('app_admin_utilisateur_delete', {id: utilisateur.id}) }}">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur.id) }}">
                                                    <button type="submit" class="btn btn-danger">Supprimer</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center">Aucun utilisateur trouvé</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
