{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Rôles{% endblock %}

{% block body %}
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Gestion des Rôles</h1>
    <a href="{{ path('app_admin_role_new') }}" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
        <i class="fas fa-plus fa-sm text-white-50"></i> Nouveau Rôle
    </a>
</div>

<!-- Search -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Recherche</h6>
    </div>
    <div class="card-body">
        <form method="get" class="form-inline">
            <div class="form-group mr-2 mb-2">
                <input type="text" name="search" class="form-control" placeholder="Rechercher un rôle..." value="{{ search }}">
            </div>
            <button type="submit" class="btn btn-primary mb-2">
                <i class="fas fa-search"></i> Rechercher
            </button>
            {% if search %}
                <a href="{{ path('app_admin_role_index') }}" class="btn btn-secondary mb-2 ml-2">
                    <i class="fas fa-times"></i> Réinitialiser
                </a>
            {% endif %}
        </form>
    </div>
</div>

<!-- Roles Cards -->
<div class="row">
    {% for role in roles %}
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">{{ role.nom }}</h6>
                    <span class="badge badge-info">{{ role.utilisateurs|length }} utilisateur(s)</span>
                </div>
                <div class="card-body">
                    <p class="text-muted">{{ role.description|default('Aucune description') }}</p>
                    
                    <h6 class="mt-3 mb-2 font-weight-bold">Permissions:</h6>
                    {% if role.permissions|length > 0 %}
                        <div class="permissions-list" style="max-height: 150px; overflow-y: auto;">
                            {% for permission in role.permissions %}
                                <span class="badge badge-secondary badge-sm mb-1">{{ permission }}</span>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-muted small">Aucune permission</p>
                    {% endif %}
                    
                    <small class="text-muted d-block mt-3">
                        <i class="fas fa-calendar"></i> Créé le {{ role.createdAt|date('d/m/Y') }}
                    </small>
                </div>
                <div class="card-footer">
                    <div class="btn-group btn-group-sm w-100" role="group">
                        <a href="{{ path('app_admin_role_show', {id: role.id}) }}" class="btn btn-info">
                            <i class="fas fa-eye"></i> Voir
                        </a>
                        <a href="{{ path('app_admin_role_edit', {id: role.id}) }}" class="btn btn-warning">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                        <button type="button" class="btn btn-danger" data-toggle="modal" data-target="#deleteModal{{ role.id }}">
                            <i class="fas fa-trash"></i> Supprimer
                        </button>
                    </div>
                </div>
            </div>

            <!-- Delete Modal -->
            <div class="modal fade" id="deleteModal{{ role.id }}" tabindex="-1" role="dialog">
                <div class="modal-dialog" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Confirmer la suppression</h5>
                            <button type="button" class="close" data-dismiss="modal">
                                <span>&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            Êtes-vous sûr de vouloir supprimer le rôle <strong>{{ role.nom }}</strong> ?
                            {% if role.utilisateurs|length > 0 %}
                                <br><br>
                                <div class="alert alert-warning">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    Ce rôle est attribué à {{ role.utilisateurs|length }} utilisateur(s). Vous ne pouvez pas le supprimer.
                                </div>
                            {% endif %}
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                            {% if role.utilisateurs|length == 0 %}
                                <form method="post" action="{{ path('app_admin_role_delete', {id: role.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ role.id) }}">
                                    <button type="submit" class="btn btn-danger">Supprimer</button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> Aucun rôle trouvé
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}
